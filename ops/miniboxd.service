[Unit]
Description=Minibox daemon
After=network.target
Wants=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/miniboxd
Restart=on-failure
RestartSec=2
User=root
Group=root
Slice=minibox.slice
Delegate=yes
DelegateSubgroup=yes
Environment=MINIBOX_CGROUP_ROOT=/sys/fs/cgroup/minibox.slice/miniboxd.service/yes/minibox
RuntimeDirectory=minibox
RuntimeDirectoryMode=0700
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
