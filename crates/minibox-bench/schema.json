{
  "type": "object",
  "required": ["metadata", "suites", "errors"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["timestamp", "hostname", "git_sha", "minibox_version"],
      "properties": {
        "timestamp": {"type": "string"},
        "hostname": {"type": "string"},
        "git_sha": {"type": "string"},
        "minibox_version": {"type": "string"}
      }
    },
    "suites": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "tests"],
        "properties": {
          "name": {"type": "string"},
          "tests": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "iterations", "durations_micros"],
              "properties": {
                "name": {"type": "string"},
                "iterations": {"type": "integer", "minimum": 0},
                "durations_micros": {
                  "type": "array",
                  "items": {"type": "integer", "minimum": 0}
                }
              }
            }
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
