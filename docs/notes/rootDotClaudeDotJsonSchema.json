{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "description": "Claude Code local configuration and state file",
    "properties": {
        "numStartups": {
            "type": "integer",
            "description": "Total number of times Claude Code has been started"
        },
        "verbose": {
            "type": "boolean",
            "description": "Whether verbose output mode is enabled"
        },
        "hasSeenTasksHint": {
            "type": "boolean"
        },
        "customApiKeyResponses": {
            "type": "object",
            "properties": {
                "approved": { "type": "array", "items": { "type": "string" } },
                "rejected": { "type": "array", "items": { "type": "string" } }
            },
            "description": "User decisions on custom API keys"
        },
        "tipsHistory": {
            "type": "object",
            "additionalProperties": { "type": "integer" },
            "description": "Map of tip ID -> startup number when tip was shown"
        },
        "promptQueueUseCount": {
            "type": "integer",
            "description": "Total prompt queue invocations"
        },
        "btwUseCount": {
            "type": "integer",
            "description": "Number of 'by the way' tip impressions"
        },
        "cachedGrowthBookFeatures": {
            "type": "object",
            "additionalProperties": true,
            "description": "Server-side feature flags (tengu_*), cached locally. Values are bool|int|string|object."
        },
        "copyFullResponse": { "type": "boolean" },
        "firstStartTime": {
            "type": "string",
            "format": "date-time",
            "description": "ISO timestamp of first startup"
        },
        "opusProMigrationComplete": { "type": "boolean" },
        "sonnet1m45MigrationComplete": { "type": "boolean" },
        "userID": {
            "type": "string",
            "description": "Unique user identifier (hash)"
        },
        "changelogLastFetched": {
            "type": "integer",
            "description": "Unix timestamp (ms) of last changelog fetch"
        },
        "claudeCodeFirstTokenDate": {
            "type": "string",
            "format": "date-time",
            "description": "When the user first received a Claude Code API token"
        },
        "hasCompletedOnboarding": { "type": "boolean" },
        "lastOnboardingVersion": {
            "type": "string",
            "description": "Semver of last completed onboarding"
        },
        "projects": {
            "type": "object",
            "additionalProperties": { "type": "object" },
            "description": "Map of absolute project path -> per-project config/state"
        },
        "githubRepoPaths": {
            "type": "object",
            "additionalProperties": { "type": "object" },
            "description": "Map of 'owner/repo' -> repo metadata/config"
        },
        "effortCalloutV2Dismissed": { "type": "boolean" },
        "lastReleaseNotesSeen": { "type": "string" },
        "clientDataCache": {
            "type": "object",
            "properties": {
                "data": { "type": "object" },
                "timestamp": { "type": "integer" }
            }
        },
        "penguinModeOrgEnabled": { "type": "boolean" },
        "groveConfigCache": {
            "type": "object",
            "additionalProperties": { "type": "object" },
            "description": "Cached grove (org?) configuration keyed by UUID"
        },
        "passesEligibilityCache": {
            "type": "object",
            "additionalProperties": { "type": "object" }
        },
        "cachedExtraUsageDisabledReason": { "type": "string" },
        "officialMarketplaceAutoInstallAttempted": { "type": "boolean" },
        "officialMarketplaceAutoInstalled": { "type": "boolean" },
        "lastPlanModeUse": {
            "type": "integer",
            "description": "Unix timestamp (ms) of last plan mode usage"
        },
        "passesUpsellSeenCount": { "type": "integer" },
        "hasVisitedPasses": { "type": "boolean" },
        "passesLastSeenRemaining": { "type": "integer" },
        "voiceNoticeSeenCount": { "type": "integer" },
        "skillUsage": {
            "type": "object",
            "additionalProperties": {
                "type": ["integer", "object"],
                "description": "Count or {count, lastUsed} for each skill"
            },
            "description": "Map of skill name -> usage tracking"
        },
        "hasIdeOnboardingBeenShown": {
            "type": "object",
            "additionalProperties": { "type": "boolean" }
        },
        "ideHintShownCount": { "type": "integer" },
        "showSpinnerTree": { "type": "boolean" },
        "claudeAiMcpEverConnected": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of cloud MCP server names that have been connected"
        },
        "feedbackSurveyState": {
            "type": "object",
            "properties": {
                "lastShownTime": { "type": "integer" }
            }
        },
        "subscriptionNoticeCount": { "type": "integer" },
        "hasAvailableSubscription": { "type": "boolean" },
        "hasUsedBackslashReturn": { "type": "boolean" },
        "anonymousId": { "type": "string" },
        "metricsStatusCache": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "timestamp": { "type": "integer" }
            }
        },
        "additionalModelOptionsCache": { "type": "array" },
        "lspRecommendationIgnoredCount": { "type": "integer" },
        "migrationVersion": {
            "type": "integer",
            "description": "Schema migration version for this file"
        },
        "oauthAccount": {
            "type": "object",
            "properties": {
                "accountUuid": { "type": "string" },
                "emailAddress": { "type": "string" },
                "organizationUuid": { "type": "string" },
                "hasExtraUsageEnabled": { "type": "boolean" },
                "billingType": { "type": "string" },
                "accountCreatedAt": { "type": "string", "format": "date-time" },
                "subscriptionCreatedAt": {
                    "type": "string",
                    "format": "date-time"
                },
                "displayName": { "type": "string" },
                "organizationRole": { "type": "string" },
                "workspaceRole": { "type": "string" }
            }
        },
        "hasResetAutoModeOptInForDefaultOffer": { "type": "boolean" }
    }
}
