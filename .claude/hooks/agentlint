#!/usr/bin/env nu
# agentlint — validate agent config files on Claude Edit/Write
#
# Checks files in .claude/, .codex/, .agents/, .cursor/:
#   .json → JSON parse validity
#   .md   → required frontmatter keys (name, description)

let input = open --raw /dev/stdin | from json

let file_path = (
    try { $input | get tool_input.file_path }
    | default (try { $input | get input.file_path } | default "")
)

let agent_dirs = [".claude/" ".codex/" ".agents/" ".cursor/"]
let is_agent_file = ($agent_dirs | any { |d| $file_path | str contains $d })

if not $is_agent_file {
    exit 0
}

if not ($file_path | path exists) {
    exit 0
}

let ext = $file_path | path parse | get extension

match $ext {
    "json" => {
        let result = do { open $file_path | ignore } | complete
        if $result.exit_code != 0 {
            print $"agentlint ERROR: ($file_path) invalid JSON"
            exit 1
        }
        print $"agentlint: ($file_path) valid JSON"
    }
    "md" => {
        let content = open --raw $file_path
        if ($content | str starts-with "---") {
            let missing = ["name:" "description:"] | where { |k| not ($content | str contains $k) }
            if ($missing | length) > 0 {
                print $"agentlint ERROR: ($file_path) frontmatter missing: ($missing | str join ', ')"
                exit 1
            }
            print $"agentlint: ($file_path) frontmatter OK"
        }
    }
    _ => { exit 0 }
}
