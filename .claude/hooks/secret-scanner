#!/usr/bin/env bash
# PostToolUse hook: scans written/edited files for secrets using obfsck redact
# and gitleaks. Blocks the operation if either tool finds a secret.
set -euo pipefail

RAW="$(cat)"
FILE_PATH="$(printf '%s' "$RAW" | jq -r '.tool_input.file_path // ""' 2>/dev/null || echo "")"

if [[ -z "$FILE_PATH" || ! -f "$FILE_PATH" ]]; then
  exit 0
fi

# Only scan text files
if ! file "$FILE_PATH" | grep -qE 'text|ASCII|UTF'; then
  exit 0
fi

block() {
  local reason="$1"
  local escaped="${reason//\"/\\\"}"
  printf '{"decision":"block","decisionReason":"%s"}\n' "$escaped"
  exit 0
}

find_bin() {
  local name="$1"; shift
  for dir in "$@"; do
    [[ -x "$dir/$name" ]] && { echo "$dir/$name"; return; }
  done
}

# ── 1. obfsck redact ─────────────────────────────────────────────────────────
REDACT_BIN="$(find_bin redact \
  "$HOME/.local/bin" \
  "$HOME/.cargo/bin" \
  "/usr/local/bin" || true)"

if [[ -n "$REDACT_BIN" ]]; then
  ORIGINAL="$(cat "$FILE_PATH")"
  REDACTED="$("$REDACT_BIN" --level minimal <<< "$ORIGINAL" 2>/dev/null)"
  if [[ "$ORIGINAL" != "$REDACTED" ]]; then
    LABEL="$(echo "$REDACTED" | grep -oP '\[REDACTED-[A-Z0-9_-]+\]' | head -1 || echo "[REDACTED]")"
    block "obfsck: secret detected (${LABEL}) in $(basename "$FILE_PATH") — remove before saving"
  fi
fi

# ── 2. gitleaks ──────────────────────────────────────────────────────────────
GITLEAKS_BIN="$(find_bin gitleaks \
  "$HOME/.local/bin" \
  "/home/linuxbrew/.linuxbrew/bin" \
  "/usr/local/bin" \
  "/usr/bin" || true)"

if [[ -n "$GITLEAKS_BIN" ]]; then
  TMPJSON="$(mktemp /tmp/gitleaks-XXXXXX.json)"
  trap 'rm -f "$TMPJSON"' EXIT
  EXIT_CODE=0
  "$GITLEAKS_BIN" detect --pipe --no-banner \
    --report-format json --report-path "$TMPJSON" \
    < "$FILE_PATH" 2>/dev/null || EXIT_CODE=$?
  if [[ $EXIT_CODE -ne 0 ]]; then
    RULE="$(jq -r '.[0].RuleID // "unknown"' "$TMPJSON" 2>/dev/null || echo "unknown")"
    block "gitleaks: secret detected (rule: ${RULE}) in $(basename "$FILE_PATH") — remove before saving"
  fi
fi

exit 0
