{
  "hooks": {
    "BeforeSubmitPrompt": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jit-context"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "secret-scanner"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "self-review"
          },
          {
            "type": "command",
            "command": "knowledge-update"
          }
        ]
      }
    ]
  }
}
