{
  "permissions": {
    "allow": [
      "Bash(cargo:*)",
      "Bash(cargo xtask:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo metadata:*)",
      "Bash(just:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git stash:*)",
      "Bash(git checkout:*)",
      "Bash(git merge:*)",
      "Bash(git branch:*)",
      "Bash(git mv:*)",
      "Bash(git revert:*)",
      "Bash(git worktree:*)",
      "Bash(git config:*)",
      "Bash(git check-ignore:*)",
      "Bash(gh:*)",
      "Bash(op item:*)",
      "Bash(op vault:*)",
      "Bash(op run:*)",
      "Bash(op account:*)",
      "Bash(op whoami:*)",
      "Bash(op read:*)",
      "Bash(rustc --version)",
      "Bash(rustup toolchain:*)",
      "Bash(doob todo:*)",
      "Bash(doob handoff:*)",
      "Bash(handoff-detect:*)",
      "Bash(gkg index:*)",
      "Bash(nu:*)",
      "Bash(minibox:*)",
      "Bash(tailscale status:*)",
      "Bash(mise:*)",
      "Bash(ssh-add -l)",
      "Bash(devloop:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:users.rust-lang.org)",
      "Read(/Users/joe/dev/minibox/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "nu scripts/preflight.nu"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cargo xtask check-protocol-drift --hook --warn-only"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/jit-context"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cargo xtask check-protocol-drift --hook --warn-only"
          },
          {
            "type": "command",
            "command": ".claude/hooks/secret-scanner"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/knowledge-update"
          }
        ]
      }
    ]
  }
}
